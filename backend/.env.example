REPLICATE_API_TOKEN=r8_xxxxxxxx
# Replicate 모델 카드의 owner/model 형식 (예: cuuupid/idm-vton). yisol/IDM-VTON 등 실제 존재하는 슬러그로 변경 가능
REPLICATE_MODEL=cuuupid/idm-vton
