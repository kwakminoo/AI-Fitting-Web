# FASHN VTON v1.5 사전학습 가중치 디렉터리 (model.safetensors, dwpose/ 포함)
# 비우면 backend/weights 기준
# FASHN_WEIGHTS_DIR=/absolute/path/to/backend/weights

# 의류 카테고리: tops | bottoms | one-pieces
# FASHN_CATEGORY=tops

# 구 Replicate 호환 매핑: upper_body -> tops, lower_body -> bottoms, dresses -> one-pieces
# REPLICATE_CATEGORY=upper_body

# 의류 이미지 유형: model(모델 착용) | flat-lay(평면 상품)
# FASHN_GARMENT_PHOTO_TYPE=model

# 추론 옵션
# FASHN_NUM_TIMESTEPS=30
# FASHN_GUIDANCE_SCALE=1.5
# FASHN_SEED=42

# 디바이스 강제: cuda | cpu (비우면 자동)
# FASHN_DEVICE=cuda

# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
# MAX_UPLOAD_BYTES=15728640
