REPLICATE_API_TOKEN=r8_xxxxxxxx
# Replicate 모델 카드의 owner/model 형식 (예: cuuupid/idm-vton). yisol/IDM-VTON 등 실제 존재하는 슬러그로 변경 가능
REPLICATE_MODEL=cuuupid/idm-vton
# 선택: 64자 버전 ID(모델 페이지 Versions). 비우면 latest_version 자동 조회
# REPLICATE_VERSION=
# 옵션
# REPLICATE_POLL_INTERVAL_SEC=1.5
# REPLICATE_MAX_WAIT_SEC=600
# REPLICATE_GARMENT_DES=Short sleeve t-shirt
# REPLICATE_CATEGORY=upper_body
#   upper_body | lower_body | dresses — 어떤 부위 옷을 바꿀지(기본 상의)
# REPLICATE_CROP=true
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
# MAX_UPLOAD_BYTES=15728640
